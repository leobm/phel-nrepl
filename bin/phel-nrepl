#!/usr/bin/env php
<?php

declare(strict_types=1);

error_reporting(E_ALL & ~E_DEPRECATED);

// Find the autoloader by walking up the directory tree
// Works when run from package root, as a Composer dependency (symlinked or copied)
$dir = __DIR__;
$autoloader = null;
for ($i = 0; $i < 10; $i++) {
    $candidate = $dir . '/vendor/autoload.php';
    if (file_exists($candidate)) {
        // Prefer the topmost project autoloader when symlinked
        $autoloader = realpath($candidate);
    }
    $parent = dirname($dir);
    if ($parent === $dir) break;
    $dir = $parent;
}

if ($autoloader === null) {
    fwrite(STDERR, "Could not find Composer autoloader. Run 'composer install' first.\n");
    exit(1);
}

require $autoloader;

// Determine the project root (where composer.json lives)
$projectRoot = dirname($autoloader, 2);

// Port file is now written by the Phel code AFTER TcpServer starts listening
// This ensures Calva only connects when the server is ready
$port = 7888;
$portFile = $projectRoot . '/.nrepl-port';

// Clean up .nrepl-port on shutdown
register_shutdown_function(function () use ($portFile) {
    if (file_exists($portFile)) {
        unlink($portFile);
    }
});

use Gacela\Framework\Gacela;
use Phel\Phel;
use Phel\Lang\Registry;
use Phel\Run\RunFacade;

Gacela::bootstrap($projectRoot, Phel::configFn());

// Load the nREPL namespace (defines functions but does not auto-start)
$runFacade = new RunFacade();
$runFacade->runNamespace('PhelNrepl\\Server');

// Call start-server from PHP via the Registry
$startServer = Registry::getInstance()->getDefinition('PhelNrepl\\Server', 'start-server');
$startServer('127.0.0.1', 7888);
