{
    "name": "phel-lang/phel-nrepl",
    "description": "nREPL server for Phel, enabling interactive development with Calva and other nREPL clients",
    "version": "0.2.0",
    "type": "library",
    "license": "MIT",
    "keywords": ["phel", "nrepl", "repl", "calva"],
    "require": {
        "php": ">=8.1",
        "phel-lang/phel-lang": "^0.31",
        "react/socket": "^1.12",
        "rhilip/bencode": "^2.5"
    },
    "autoload": {
        "psr-4": {
            "PhelNrepl\\": "src/php/"
        }
    },
    "bin": ["bin/phel-nrepl"],
    "config": {
        "allow-plugins": {
            "phel-lang/phel-composer-registrar": true
        }
    }
}
